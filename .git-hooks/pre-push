#!/bin/sh
# To setup git hooks run:
#   > git config core.hooksPath .git-hooks || echo 'Not in a git repo'
echo "Running .git-hooks/pre-push — checking 100% test coverage..."

COVER_OUT=$(mktemp)
trap 'rm -f "$COVER_OUT"' EXIT

go test ./... -count=1 -coverprofile="$COVER_OUT" -covermode=atomic
if [ $? -ne 0 ]; then
  echo "FAIL: tests did not pass"
  exit 1
fi

PCT=$(go tool cover -func="$COVER_OUT" | awk '/^total:/ {gsub(/%/,""); print $NF}')
echo "Total coverage: ${PCT}%"
if [ "$(echo "$PCT < 100" | bc -l)" -eq 1 ]; then
  echo "FAIL: coverage ${PCT}% is below 100% threshold"
  go tool cover -func="$COVER_OUT" | grep -v '100.0%'
  exit 1
fi

echo "OK: 100% coverage"
